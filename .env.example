## Jarspect example environment
## Copy to .env and fill required values.

# Server
JARSPECT_BIND=127.0.0.1:18000
JARSPECT_WEB_DIR=web
JARSPECT_RULEPACKS=demo

# Optional: disable AI verdict even if Azure OpenAI env vars are set
# Values: 1/true (default) = enable, 0/false = disable
JARSPECT_AI_ENABLED=1

# Optional: max accepted upload size in bytes (default: 52428800 = 50 MiB)
JARSPECT_UPLOAD_MAX_BYTES=52428800

# Optional: Threat intel (enables known-malware short-circuit)
MALWAREBAZAAR_API_KEY=

# Optional: Disable MalwareBazaar hash matching (useful when scanning MalwareBazaar samples
# to evaluate static/AI detectors instead of trivially labeling by hash).
# Values: 1/true (default) = enable, 0/false = disable
JARSPECT_MB_HASH_MATCH_ENABLED=1

# Optional: When a MalwareBazaar hash match occurs, still run archive traversal + static analysis
# so the persisted scan JSON includes capability/profile artifacts for reporting.
# Final verdict stays MALICIOUS with method "malwarebazaar_hash".
# Values: 0/false (default) = short-circuit, 1/true = continue static analysis
JARSPECT_MB_MATCH_CONTINUE_ANALYSIS=0

# Required: AI verdict (Azure OpenAI)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# Logging
RUST_LOG=jarspect=info,tower_http=info
